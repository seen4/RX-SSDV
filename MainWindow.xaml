<Window x:Class="RX_SSDV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RX_SSDV"
        mc:Ignorable="d"
        Title="RX-SSDV" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="{DynamicResource MainWindow_TabSpectrum}" d:Header="Spectrum">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="600*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="500*"/>
                            <RowDefinition Height="130"/>
                        </Grid.RowDefinitions>
                        <Canvas Name="spectrum" Margin="10,10,0,10" Grid.Row ="0" Background="#FFBBBBBB">
                            <Image Name="spectrumDisplay"/>
                        </Canvas>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="1">
                            <Canvas Margin="10,0,0,0">
                                <Label Content="PM" FontSize="10"/>
                                <Canvas Margin="0,20,0,0" Name="pm" Width="100" Height="100" Grid.Row ="0" Background="#FFBBBBBB">
                                    <Image Name="pmDisplay"/>
                                </Canvas>
                            </Canvas>

                            <Canvas Margin="110,0,0,0">
                                <Label Content="Constellation" FontSize="10"/>
                                <Canvas Margin="0,20,0,0" Name="constellation" Width="100" Height="100" Grid.Row ="0" Background="#FFBBBBBB">
                                    <Image Name="constellationDisplay"/>
                                </Canvas>
                            </Canvas>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Column="1" >
                        <Grid Margin="5,10,5,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="200*"/>
                            </Grid.RowDefinitions>
                            <GroupBox Header="Data Source" Grid.Row="0">
                                <StackPanel Orientation="Vertical" Grid.Row="0" Margin="5,5,5,5">
                                    <ComboBox Name="dataSourceType" SelectedIndex="0" SelectionChanged="dataSourceType_SelectionChanged">
                                        <ComboBoxItem Content="Baseband File"/>
                                        <ComboBoxItem Content="RTL-SDR"/>
                                    </ComboBox>
                                    <StackPanel Orientation="Vertical" Margin="0,5,0,0">
                                        <TextBox Name="audioPathInput" TextChanged="audioPathInput_TextChanged"/>
                                        <Button Name="browseAudioFileBtn" Content="Browse" Margin="0,5,0,0" Click="browseAudioFileBtn_Click"/>
                                        <!--<Label Name="audioProgress" Content="00:00 / 00:00" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        <Slider Name="audioProgressSlider" Value="0.0" Maximum="100"/>-->
                                        <Button Name="playAudioBtn" Content="Play" Margin="0,10,0,0" Click="playAudioBtn_Click"/>
                                        <Button Name="pauseAudioBtn" Content="Pause" Margin="0,5,0,0" Click="pauseAudioBtn_Click"/>
                                        <Button Name="stopAudioBtn" Content="Stop" Margin="0,5,0,0" Click="stopAudioBtn_Click"/>
                                        <Grid Margin="0,5,0,0">
                                            <Label Content="Read Period(ms)"/>
                                            <TextBox Name="sampleReadPeriodInput" LostFocus="sampleReadPeriodInput_LostFocus" Margin="120,0,5,0" Text="0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Display" Grid.Row="1">
                                <StackPanel Orientation="Vertical">
                                    <Grid Margin="0,0,0,0">
                                        <Label Content="Drawer Period"/>
                                        <TextBox Name="drawerPeriodInput" LostFocus="drawerPeriodInput_LostFocus" Margin="120,0,5,0" Text="1"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Filter" Grid.Row="2">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox Name="enableFilterBox" Click="enableFilterBox_Click" Content="Enable Filter"/>
                                    <Grid Margin="0,5,0,0">
                                        <Label Content="Bandwidth"/>
                                        <TextBox Name="bandWidthInput" LostFocus="bandWidthInput_LostFocus" Margin="80,0,5,0" Text="1"/>
                                    </Grid>
                                    <Grid Margin="0,5,0,0">
                                        <Label Content="Freq Shift"/>
                                        <TextBox Name="freqShiftInput" LostFocus="freqShiftInput_LostFocus" Margin="80,0,5,0" Text="0"/>
                                    </Grid>
                                    <!--<Button Name="applyFilterBtn" Click="applyFilterBtn_Click" Width="70" Height="20" Content="Apply" FontSize="12" Margin="0,30,0,0"/>-->
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Process" Grid.Row="3">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox Name="enableProcessorBox" Click="enableProcessorBox_Click" Content="Enable Process"/>
                                    <Grid Margin="0,5,0,0">
                                        <Label Content="Cons Scale"/>
                                        <TextBox Name="constellationScaleBox" LostFocus="constellationScaleBox_LostFocus" Margin="80,0,5,0" Text="0"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource MainWindow_TabProcess}" d:Header="Process">

            </TabItem>
            <TabItem Header="{DynamicResource MainWindow_TabSettings}" d:Header="Setting">

            </TabItem>
            <TabItem Header="{DynamicResource MainWindow_TabLog}" d:Header="Log">

            </TabItem>
        </TabControl>
    </Grid>
</Window>
